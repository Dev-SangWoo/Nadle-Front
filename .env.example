# 카카오 개발자 콘솔(https://developers.kakao.com) > 내 애플리케이션 > 앱 키 > JavaScript 키
# 플랫폼에 웹 도메인 등록: http://localhost:5173 (개발), 배포 도메인(운영)
VITE_KAKAO_MAP_APP_KEY=

# Nadle 백엔드 (끝의 / 는 없어도 됨 — 코드에서 정규화함)
# 로컬 npm run dev: Vite가 /api 를 이 주소로 프록시(CORS 우회). 빌드/배포 시에는 직접 호출.
VITE_API_BASE_URL=https://nadle-backend.onrender.com
